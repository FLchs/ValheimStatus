{
  "name": "valheimstatus",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter web dev",
    "build": "bun run --filter web build",
    "typecheck": "bun run --filter web typecheck",
    "lint": "oxlint apps/ packages/",
    "lint:ox": "oxlint apps/ packages/",
    "format": "oxfmt apps/ packages/",
    "format:check": "oxfmt apps/ packages/ --check",
    "preview": "bun run --filter web preview",
    "i18n:extract": "bun run --filter web i18n:extract",
    "i18n:compile": "bun run --filter web i18n:compile"
  },
  "devDependencies": {
    "oxlint": "^1.50.0"
  }
}
