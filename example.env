# Copy this file to .env and customize for your setup
# Vite requires env variables to start with VITE_ to be exposed to the client

# API URL for fetching status.json (used in usePingLatency.ts)
# - In development: Leave EMPTY to use Vite proxy (avoids CORS issues)
#   The proxy target is configured in vite.config.ts
# - In production: Set to your actual API endpoint URL
VITE_API_URL=

# Server address displayed in the UI (shown in App.tsx)
# This is what users see as the server address to join
# This does NOT affect API calls - only the displayed address
VITE_SERVER_ADDRESS=YOUR_SERVER_ADDRESS
